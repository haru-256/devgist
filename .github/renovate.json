{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "crawler: minor/patch を1PRにまとめる",
      "matchFileNames": ["workflows/crawler/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "crawler deps (minor/patch)"
    },
    {
      "description": "terraform: minor/patch を1PRにまとめる",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "terraform (minor/patch)"
    },
    {
      "description": "github-actions: minor/patch を1PRにまとめる",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions (minor/patch)"
    }
  ]
}
