{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "crawler: minor/patch を1PRにまとめる",
      "matchFileNames": ["workflows/crawler/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "crawler deps (minor/patch)"
    },
    {
      "description": "terraform: environment (parentDir) ごとに minor/patch を1PRにまとめる",
      "matchManagers": ["terraform"],
      "matchFileNames": ["infra/terraform/environments/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "terraform/{{parentDir}} (minor/patch)"
    },
    {
      "description": "github-actions: minor/patch を1PRにまとめる",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions (minor/patch)"
    }
  ]
}
